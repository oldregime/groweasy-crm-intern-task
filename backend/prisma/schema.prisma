// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id                          String   @id @default(uuid())
  import_session_id           String
  created_at                  String?  // JS-convertible date string
  name                        String?
  email                       String?
  country_code                String?
  mobile_without_country_code String?
  company                     String?
  city                        String?
  state                       String?
  country                     String?
  lead_owner                  String?
  crm_status                  String?  // GOOD_LEAD_FOLLOW_UP, DID_NOT_CONNECT, BAD_LEAD, SALE_DONE
  crm_note                    String?
  data_source                 String?  // leads_on_demand, meridian_tower, eden_park, varah_swamy, sarjapur_plots
  possession_time             String?
  description                 String?
  is_skipped                  Boolean  @default(false)
  skip_reason                 String?  // Reason for skipping the record
  db_created_at               DateTime @default(now())

  @@index([import_session_id])
}
